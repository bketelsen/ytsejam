{
  "name": "ytsejam",
  "license": "MIT",
  "engines": { "node": ">=22.0.0" },
  "type": "module",
  "workspaces": [
    "server",
    "web",
    "packages/ltm"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bketelsen/ytsejam.git"
  },
  "bugs": {
    "url": "https://github.com/bketelsen/ytsejam/issues"
  },
  "homepage": "https://github.com/bketelsen/ytsejam#readme",
  "scripts": {
    "postinstall": "patch-package",
    "test": "npm test --workspace server && npm test --workspace web && npm test --workspace ltm",
    "check": "npm run check --workspace server && npm run check --workspace ltm",
    "build": "npm run build --workspace web",
    "dev:server": "npm run dev --workspace server",
    "dev:web": "npm run dev --workspace web",
    "start": "npm run build && npm run start --workspace server"
  },
  "devDependencies": {
    "patch-package": "^8.0.1"
  }
}
