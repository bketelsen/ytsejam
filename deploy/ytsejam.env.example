# ytsejam production environment
# Copied to ~/.ytsejam/ytsejam.env (mode 0600) by deploy/install.sh.
# systemd reads this via EnvironmentFile=, AFTER the unit's own Environment=
# defaults, so any key set here overrides the unit.
#
# IMPORTANT: systemd does NOT expand ${HOME} or ~ inside this file. Path
# defaults (data dir, web dist, pi auth, port) are set in the unit
# using %h, which systemd expands correctly — so you normally set NONE of them
# here. Only override a path here if you use an ABSOLUTE path (e.g.
# YTSEJAM_DATA_DIR=/mnt/big/ytsejam-data).

# ── Required ──
# Shared login token. CHANGE THIS to something unguessable.
YTSEJAM_AUTH_TOKEN=change-me

# ── Model selection ──
# "provider/modelId" — must exist in the pi-ai catalog. Examples:
#   anthropic/claude-sonnet-4-6        (needs ANTHROPIC_API_KEY)
#   github-copilot/claude-opus-4.7     (needs pi CLI OAuth — see the unit's YTSEJAM_PI_AUTH)
YTSEJAM_DEFAULT_MODEL=anthropic/claude-sonnet-4-6
# Model for delegated background subagents (defaults to YTSEJAM_DEFAULT_MODEL).
#YTSEJAM_SUBAGENT_MODEL=anthropic/claude-sonnet-4-6

# Disable the GitHub Copilot live catalog fetch at boot. When unset (default),
# ytsejam fetches Copilot's /models endpoint at startup to merge live model
# availability with pi-ai's static catalog. Set to "1" to skip the fetch and
# fall back to pi-ai's catalog only — useful for offline diagnostics or if
# Copilot's /models endpoint is unreachable for an extended period.
#YTSEJAM_DISABLE_COPILOT_LIVE_CATALOG=1

# ── Provider credentials (set the ones you use) ──
#ANTHROPIC_API_KEY=
#OPENAI_API_KEY=

# ── LTM embedder selection ──
# Which embedder LTM uses for semantic retrieval. Defaults to "auto":
#   • auto    — try Copilot (if creds present), then Ollama (if reachable),
#               else fall back to hash. Logs which it picked.
#   • copilot — require Copilot. Refuses to boot LTM if no creds. Best quality,
#               1536-dim, depends on github-copilot OAuth (set up via `pi /login`).
#   • ollama  — require Ollama. Refuses to boot LTM if unreachable. 768-dim.
#   • hash    — pure deterministic hash embedding, 256-dim. No external service.
#
# IMPORTANT: changing the embedder dimension after first boot will cause LTM to
# refuse to attach (different vector dimensions can't share an index). On
# mismatch the server logs a [memory] WARN with the remediation command and
# continues with cog-only memory. To rebuild and re-embed under the new model:
#
#   node /home/<you>/.ytsejam/current/server/src/index.ts ltm replay --rebuild
#
# This re-embeds current observations under the new embedder. Add --prune to
# also tombstone orphan records (observations whose source line is no longer in
# cog memory). Only use --prune in steady state -- NOT during archival or
# restoration, because temporarily missing source lines will be tombstoned.
#
# Recommended for prod: pin to "copilot" so a Copilot outage is loud (cog-only)
# rather than silently degraded to hash.
YTSEJAM_LTM_EMBEDDER=copilot

# Optional model/URL overrides. Leave commented to use defaults.
#YTSEJAM_LTM_COPILOT_MODEL=text-embedding-3-small
#YTSEJAM_LTM_COPILOT_URL=https://api.enterprise.githubcopilot.com
#YTSEJAM_LTM_OLLAMA_MODEL=nomic-embed-text:latest
#YTSEJAM_LTM_OLLAMA_URL=http://localhost:11434

# ── Optional tools / knobs ──
# (Comments must be on their OWN line — systemd EnvironmentFile does NOT strip a
#  trailing "# ..." from a value, so `KEY=4  # note` is read literally as "4  # note".)
# enables the web_search tool
#BRAVE_API_KEY=
# LLM-generated session titles
#YTSEJAM_GENERATE_TITLES=true
# load AGENTS.md/CLAUDE.md context files
#YTSEJAM_CONTEXT_FILES=true
# max concurrent subagent tasks
#YTSEJAM_TASK_CONCURRENCY=4
# per-task timeout (minutes)
#YTSEJAM_TASK_TIMEOUT_MIN=15

# Context-window compaction kill switch.
# Defaults to enabled. Set to "false" (case-insensitive) to disable
# auto-compaction entirely. When disabled, sessions will 400 with
# "prompt is too long" on context overflow (the pre-compaction behavior).
#
# Emergency override only — if a bug in the compaction module is corrupting
# sessions or otherwise misbehaving, set this to "false" in
# ~/.ytsejam/ytsejam.env and `systemctl --user restart ytsejam`. Then ship
# a fix at leisure. This is a known-bad-but-survivable state.
#
# Per-session backup chain (last 3 pre-compact JSONLs co-located with the
# session file) and per-session observability log (<session>.compactions.jsonl)
# are NOT affected by this switch — they only matter when compaction is on.
#YTSEJAM_COMPACTION_ENABLED=false

# ── Path overrides (only if absolute; defaults come from the unit via %h) ──
#YTSEJAM_DATA_DIR=/absolute/path/to/data
# Memory store root. Defaults to $YTSEJAM_DATA_DIR/memory.
# Set to an absolute path to keep the cog memory store on a different
# filesystem (e.g. a faster disk). Concurrent writers are NOT supported,
# so two ytsejam instances must not share a memory dir.
#YTSEJAM_MEMORY_DIR=/absolute/path/to/memory
# Listener hostname.
# Defaults to 127.0.0.1 (loopback-only). The HTTP listener authenticates with a
# single shared bearer token (YTSEJAM_AUTH_TOKEN) and exposes an agent with a
# `bash` tool — listening on a network interface without a reverse proxy and an
# auth review is a LAN-reachable RCE. Set to "0.0.0.0" only behind a reverse
# proxy you trust (and review the token model first).
#YTSEJAM_HOST=127.0.0.1
#YTSEJAM_PORT=9873

# ── Deploy pipeline tuning ──
# KEEP_RELEASES controls how many old release directories to keep under ~/.ytsejam/releases/
# after a successful deploy. Older releases are auto-pruned so rollback
# has a small fixed history. Read by deploy/deploy.sh, not the runtime
# server. Default: 5.
#KEEP_RELEASES=5
